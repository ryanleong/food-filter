# Copy this file to .env.local and fill in the values.
# All variables marked NEXT_PUBLIC_* are safe to expose to the browser.
# Keep GEMINI_API_KEY server-side only.

# --- Supabase ---
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Required for the "Delete account" server action (service_role key — keep server-side only!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Gemini ---
# Required for /api/analyze (server-side only, never expose to the client)
GEMINI_API_KEY=your-gemini-api-key
